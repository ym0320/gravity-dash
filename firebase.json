{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      ".firebaserc",
      ".firebase/**",
      ".git/**",
      ".github/**",
      ".expo/**",
      ".claude/**",
      ".vscode/**",
      "**/node_modules/**",
      "node_modules/**",
      "README.md",
      ".gitignore",
      ".nojekyll",
      "src/**",
      "scripts/**",
      "assets/**",
      "store-screenshots/**",
      "screenshots-raw/**",
      "package.json",
      "package-lock.json",
      "app.json",
      "eas.json",
      "babel.config.js",
      "tsconfig.json",
      "skills-lock.json",
      "App.js",
      "App.js.bak",
      "_server.js",
      "generate-icons.html",
      "icon.svg",
      "index.html.backup",
      "NGワード一覧.txt",
      "OAuth 2.0 クライアントシークレット.txt",
      "**/*.bak",
      "**/*.backup",
      "**/*.log",
      "CLAUDE.md"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
