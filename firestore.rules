rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // cosmetic ID: alphanumeric + _ - only, max 64 chars
    function isValidCosmeticId(v) {
      return v is string && v.size() <= 64 && v.matches('[a-zA-Z0-9_\\-]*');
    }

    match /users/{userId} {
      // 自分のデータのみ取得可能
      allow get: if request.auth != null && request.auth.uid == userId;
      // 名前重複チェック用の list クエリ（limit 1 のみ許可）
      allow list: if request.auth != null && request.query.limit <= 1;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 12
        && request.resource.data.highScore is int
        && request.resource.data.highScore >= 0
        && request.resource.data.highScore <= 99999
        && request.resource.data.wallet is int
        && request.resource.data.wallet >= 0
        && request.resource.data.wallet <= 9999999
        && request.resource.data.character is int
        && request.resource.data.character >= 0
        && request.resource.data.character <= 5
        && request.resource.data.unlocked is list
        && request.resource.data.unlocked.size() <= 6
        && request.resource.data.plays is int
        && request.resource.data.plays >= 0
        && request.resource.data.challBestKills is int
        && request.resource.data.challBestKills >= 0
        && request.resource.data.challBestKills <= 9999
        && (!('eqSkin'  in request.resource.data) || isValidCosmeticId(request.resource.data.eqSkin))
        && (!('eqEyes'  in request.resource.data) || isValidCosmeticId(request.resource.data.eqEyes))
        && (!('eqFx'    in request.resource.data) || isValidCosmeticId(request.resource.data.eqFx))
        && (!('rankChar' in request.resource.data) || (request.resource.data.rankChar is int && request.resource.data.rankChar >= -1 && request.resource.data.rankChar <= 5))
        && (!('rankSkin' in request.resource.data) || isValidCosmeticId(request.resource.data.rankSkin))
        && (!('rankEyes' in request.resource.data) || isValidCosmeticId(request.resource.data.rankEyes))
        && (!('rankFx'   in request.resource.data) || isValidCosmeticId(request.resource.data.rankFx))
        && (!('challRankChar' in request.resource.data) || (request.resource.data.challRankChar is int && request.resource.data.challRankChar >= -1 && request.resource.data.challRankChar <= 5))
        && (!('challRankSkin' in request.resource.data) || isValidCosmeticId(request.resource.data.challRankSkin))
        && (!('challRankEyes' in request.resource.data) || isValidCosmeticId(request.resource.data.challRankEyes))
        && (!('challRankFx'   in request.resource.data) || isValidCosmeticId(request.resource.data.challRankFx))
        && (!('storedChests' in request.resource.data) || (request.resource.data.storedChests is int && request.resource.data.storedChests >= 0 && request.resource.data.storedChests <= 999))
        && (!('freeRevives' in request.resource.data) || (request.resource.data.freeRevives is int && request.resource.data.freeRevives >= 0 && request.resource.data.freeRevives <= 5));
    }

    match /rankings/{userId} {
      // ランキングは全認証ユーザーが読める（リーダーボード表示のため）
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 12
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 99999
        && (!('char' in request.resource.data) || (request.resource.data.char is int && request.resource.data.char >= 0 && request.resource.data.char <= 5))
        && (!('eqSkin' in request.resource.data) || isValidCosmeticId(request.resource.data.eqSkin))
        && (!('eqEyes' in request.resource.data) || isValidCosmeticId(request.resource.data.eqEyes))
        && (!('eqFx'   in request.resource.data) || isValidCosmeticId(request.resource.data.eqFx));
    }

    // ステージモードの死亡マーカー（他プレイヤーとゴースト共有）
    match /stageDeaths/{docId} {
      // 認証ユーザーは読み取り可能（list はクエリのみ、limit 50以下）
      allow get: if request.auth != null;
      allow list: if request.auth != null && request.query.limit <= 50;
      // 自分の死亡のみ追加可能・他人のデータ改変は不可
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.stageId is string
        && request.resource.data.stageId.size() <= 16
        && request.resource.data.dist is number
        && request.resource.data.dist >= 0
        && request.resource.data.dist <= 10000
        && request.resource.data.py is number
        && request.resource.data.py >= -500
        && request.resource.data.py <= 2500
        && request.resource.data.gDir is number
        && (request.resource.data.gDir == 1 || request.resource.data.gDir == -1);
      allow update: if false;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /challengeRankings/{userId} {
      // チャレンジランキングも全認証ユーザーが読める
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 12
        && request.resource.data.kills is int
        && request.resource.data.kills >= 0
        && request.resource.data.kills <= 9999
        && (!('char' in request.resource.data) || (request.resource.data.char is int && request.resource.data.char >= 0 && request.resource.data.char <= 5))
        && (!('eqSkin' in request.resource.data) || isValidCosmeticId(request.resource.data.eqSkin))
        && (!('eqEyes' in request.resource.data) || isValidCosmeticId(request.resource.data.eqEyes))
        && (!('eqFx'   in request.resource.data) || isValidCosmeticId(request.resource.data.eqFx));
    }
  }
}
