{
  "expo": {
    "name": "Grav Hopper",
    "slug": "gravity-dash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ym0320.gGravHopper",
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "このアプリはカメラを使用しません",
        "NSMicrophoneUsageDescription": "このアプリはマイクを使用しません",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "gravity-dash-cdce1.web.app": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true
            },
            "firebaseapp.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true
            },
            "googleapis.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true
            },
            "accounts.google.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": false
            },
            "gstatic.com": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.ym0320.gGravHopper",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a2e"
      },
      "permissions": []
    },
    "plugins": [
      "expo-screen-orientation",
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "01c135c9-512a-43fa-8e22-ba821d4e027d"
      }
    },
    "owner": "ym3020"
  }
}
